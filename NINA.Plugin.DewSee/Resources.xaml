<ResourceDictionary
    x:Class="NINA.Plugin.DewSee.Resources"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.Plugin.DewSee"
    xmlns:vm="clr-namespace:NINA.Plugin.DewSee.ViewModels"
    xmlns:views="clr-namespace:NINA.Plugin.DewSee.Views"
    xmlns:seq="clr-namespace:NINA.Plugin.DewSee.Sequencer"
    xmlns:nina="clr-namespace:NINA.View.Sequencer;assembly=NINA.Sequencer">

    <!-- Dew drop icon — used by ExportMetadata("Icon", "DewSee_Icon") -->
    <GeometryGroup x:Key="DewSee_Icon" FillRule="Nonzero">
        <PathGeometry Figures="M12,2 L19,12 A7,7 0 1 1 5,12 Z"/>
    </GeometryGroup>

    <!-- Sequencer instruction templates -->
    <DataTemplate DataType="{x:Type seq:StartDewControlInstruction}">
        <nina:SequenceBlockView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type seq:StopDewControlInstruction}">
        <nina:SequenceBlockView/>
    </DataTemplate>

    <!-- Dockable panel data template — key must match fully qualified ViewModel type name + _Dockable -->
    <DataTemplate x:Key="NINA.Plugin.DewSee.ViewModels.DewStatusViewModel_Dockable" DataType="{x:Type vm:DewStatusViewModel}">
        <views:DewStatusView/>
    </DataTemplate>

    <!-- Plugin options UI — key must match plugin display name + _Options -->
    <DataTemplate x:Key="DewSee_Options" DataType="{x:Type local:DewSeePlugin}">
        <StackPanel Margin="8" MaxWidth="500">

            <TextBlock Text="Heater Thresholds" FontWeight="Bold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Turn ON below margin (°C):" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OnBelowThreshold, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="default 3.5°C" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,4" FontSize="11"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Turn OFF above margin (°C):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OffAboveThreshold, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="default 5.0°C" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
            </Grid>

            <Grid Margin="0,12,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Poll interval (minutes):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding PollIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="default 1" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
            </Grid>

            <TextBlock Text="Notifications" FontWeight="Bold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Discord webhook URL:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding DiscordWebhookUrl, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            </Grid>

            <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" HorizontalAlignment="Left" Padding="12,4"/>

        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
